`timescale 1ns / 1ps

module cache_system_top_tb;

    // ==========================================
    // Khai báo tín hiệu
    // ==========================================
    // Tín hiệu Clock và Reset
    reg clk;
    reg reset_n;

    // Tín hiệu giả lập CPU 
    reg cpu_rd;
    reg cpu_wr;
    reg [21:0] cpu_addr;
    reg [15:0] cpu_data_in;
    wire [15:0] cpu_data_out;
    wire cpu_wait; // CPU phải chờ khi tín hiệu này lên 1 

    // Tín hiệu giả lập SRAM (Main Memory) [cite: 152, 153]
    reg sram_ready;
    reg [15:0] sram_data_out;
    wire [15:0] sram_data_in;
    wire [21:0] sram_addr_ext;
    wire sram_rd_en;
    wire sram_wr_en;

    // ==========================================
    // Khởi tạo Device Under Test (DUT)
    // ==========================================
    cache_system_top DUT (
        .clk(clk),
        .reset_n(reset_n),
        .cpu_rd(cpu_rd),
        .cpu_wr(cpu_wr),
        .cpu_addr(cpu_addr),
        .cpu_data_in(cpu_data_in),
        .cpu_data_out(cpu_data_out),
        .cpu_wait(cpu_wait),
        .sram_ready(sram_ready),
        .sram_data_out(sram_data_out),
        .sram_data_in(sram_data_in),
        .sram_addr_ext(sram_addr_ext),
        .sram_rd_en(sram_rd_en),
        .sram_wr_en(sram_wr_en)
    );

    // ==========================================
    // Tạo xung Clock (Chu kỳ 10ns)
    // ==========================================
    always #5 clk = ~clk;

    // ==========================================
    // Giả lập hành vi của SRAM (Mock Memory)
    // ==========================================
    // Bộ nhớ chính sẽ phản hồi sau một số chu kỳ khi có yêu cầu
    always @(posedge clk) begin
        if (!reset_n) begin
            sram_ready <= 0;
            sram_data_out <= 16'h0000;
        end else begin
            // Mặc định hạ sram_ready nếu không có yêu cầu
            if (!sram_rd_en && !sram_wr_en) begin
                sram_ready <= 0;
            end
            
            // Xử lý yêu cầu đọc từ Cache (MEM_READ) [cite: 155]
            if (sram_rd_en && !sram_ready) begin
                #20; // Giả lập độ trễ truy cập SRAM 2 chu kỳ
                sram_ready <= 1;
                // Trả về dữ liệu giả định dựa trên địa chỉ
                sram_data_out <= {sram_addr_ext[7:0], 8'hAA}; 
            end
            
            // Xử lý yêu cầu ghi từ Cache (WRITE_BACK) [cite: 155, 198]
            if (sram_wr_en && !sram_ready) begin
                #20; // Giả lập độ trễ ghi SRAM
                sram_ready <= 1;
                $display("[%0t] SRAM: Đã nhận dữ liệu Ghi %h tại địa chỉ %h", $time, sram_data_in, sram_addr_ext);
            end
        end
    end

    // ==========================================
    // Các Task hỗ trợ giả lập hành vi CPU
    // ==========================================
    task cpu_read_request(input [21:0] addr);
        begin
            @(posedge clk);
            cpu_rd = 1;
            cpu_addr = addr;
            
            // Chờ FSM phản hồi và kéo cpu_wait lên 1 (nếu Miss)
            @(posedge clk);
            cpu_rd = 0; // Giả định CPU nhả tín hiệu sau 1 chu kỳ
            
            // Đợi cho đến khi Cache xử lý xong (cpu_wait rơi xuống 0) 
            wait(cpu_wait == 0);
            @(posedge clk);
            $display("[%0t] CPU READ Hoàn tất: Địa chỉ %h -> Dữ liệu %h", $time, addr, cpu_data_out);
        end
    endtask

    task cpu_write_request(input [21:0] addr, input [15:0] data);
        begin
            @(posedge clk);
            cpu_wr = 1;
            cpu_addr = addr;
            cpu_data_in = data;
            
            @(posedge clk);
            cpu_wr = 0;
            
            wait(cpu_wait == 0);
            @(posedge clk);
            $display("[%0t] CPU WRITE Hoàn tất: Đã ghi %h vào địa chỉ %h", $time, data, addr);
        end
    endtask

    // ==========================================
    // Kịch bản mô phỏng chính
    // ==========================================
    initial begin
        // Khởi tạo trạng thái ban đầu
        clk = 0;
        reset_n = 0;
        cpu_rd = 0;
        cpu_wr = 0;
        cpu_addr = 0;
        cpu_data_in = 0;

        $display("--- BẮT ĐẦU MÔ PHỎNG CACHE SYSTEM ---");

        // Giải phóng Reset
        #15 reset_n = 1;
        #10;

        // ---------------------------------------------------------
        // Kịch bản 1: Read Miss (Miss & Clean) [cite: 163]
        // Đọc một địa chỉ mới hoàn toàn. Cache trống -> Miss.
        // FSM sẽ nhảy: IDLE -> COMPARE_TAG -> MEM_READ -> UPDATE_CACHE -> IDLE [cite: 158, 163, 165]
        // ---------------------------------------------------------
        $display("\n--- KỊCH BẢN 1: READ MISS ---");
        cpu_read_request(22'h00_0004);

        // ---------------------------------------------------------
        // Kịch bản 2: Read Hit [cite: 161]
        // Đọc lại chính địa chỉ vừa nạp. FSM không cần xuống SRAM.
        // FSM sẽ nhảy: IDLE -> COMPARE_TAG -> IDLE [cite: 158, 160]
        // ---------------------------------------------------------
        $display("\n--- KỊCH BẢN 2: READ HIT ---");
        cpu_read_request(22'h00_0004);

        // ---------------------------------------------------------
        // Kịch bản 3: Write Hit [cite: 160]
        // Ghi đè lên dòng vừa nạp. Bật cờ Dirty.
        // FSM sẽ nhảy: IDLE -> COMPARE_TAG -> UPDATE_CACHE -> IDLE [cite: 158, 159, 166]
        // ---------------------------------------------------------
        $display("\n--- KỊCH BẢN 3: WRITE HIT (Tạo dòng Dirty) ---");
        cpu_write_request(22'h00_0004, 16'hDEAD);

        // ---------------------------------------------------------
        // Kịch bản 4: Write Miss dẫn đến Write-Back [cite: 162, 198]
        // Ghi vào một địa chỉ mới nhưng có cùng Index với dòng cũ (Giả định Index là 10 bit cuối).
        // FSM phát hiện dòng cũ đã Dirty -> Đẩy dòng cũ xuống SRAM trước khi nạp.
        // FSM sẽ nhảy: IDLE -> COMPARE_TAG -> WRITE_BACK -> MEM_READ -> UPDATE_CACHE -> IDLE [cite: 155, 162, 164, 165]
        // ---------------------------------------------------------
        $display("\n--- KỊCH BẢN 4: WRITE MISS kèm WRITE-BACK ---");
        // Đổi Tag (các bit cao) nhưng giữ nguyên Index để cố tình tạo xung đột (Eviction)
        cpu_write_request(22'h01_0004, 16'hBEEF);

        #50;
        $display("\n--- MÔ PHỎNG KẾT THÚC ---");
        $stop;
    end

endmodule